# ── TCAM Environment Variables ────────────────────────────────────────────────
# Copy this file to .env for local development (never commit .env to git).

# Database path (absolute path). Defaults to tcam_bookings.db in project root.
TCAM_DB_PATH=/var/data/tcam_bookings.db

# Upload directory (absolute path). Defaults to uploads/ in project root.
TCAM_UPLOAD_DIR=/var/data/uploads

# CORS: comma-separated list of allowed frontend origins, or "*" for all.
# Example: https://tcam-frontend.onrender.com,https://tcam.in
CORS_ALLOWED_ORIGINS=*

# Stateless CSRF secret — change to a long random string in production.
CSRF_SECRET=change-me-to-a-long-random-string

# Admin credentials (used to seed the admin_users table on first boot)
ADMIN_USERNAME=tcam_admin
ADMIN_PASSWORD=YourSecurePassword123!

# Frontend URL (used by backend to build absolute links if needed)
FRONTEND_URL=http://localhost
